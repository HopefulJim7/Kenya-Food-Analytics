99Z", "completed_at": "2026-04-01T23:36:14.438233Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.39898228645324707, "adapter_response": {"_message": "SELECT 18836", "code": "SELECT", "rows_affected": 18836}, "message": "SELECT 18836", "failures": null, "unique_id": "model.kenya_food_analytics.avg_commodity_prices", "compiled": true, "compiled_code": "-- Average Price per Commodity per County\n\n\n\n\nSELECT \n    c.commodity_name,\n    c.category,\n    m.county,\n    m.market_name,\n    d.month_name,\n    d.year,\n    -- Requirement #9: Calculate Average Price\n    ROUND(AVG(p.price_per_kg), 2) as average_price\nFROM \"food_prices_prod_v1\".\"food_etl\".\"fact_prices\" p\nJOIN \"food_prices_prod_v1\".\"food_etl\".\"dim_commodity\" c ON p.commodity_name = c.commodity_name\nJOIN \"food_prices_prod_v1\".\"food_etl\".\"dim_market\" m ON p.market_name = m.market_name\nJOIN \"food_prices_prod_v1\".\"food_etl\".\"dim_date\" d ON p.date_key = d.date_key\nGROUP BY 1, 2, 3, 4, 5, 6", "relation_name": "\"food_prices_prod_v1\".\"food_etl\".\"avg_commodity_prices\"", "batch_results": null}], "elapsed_time": 0.7719779014587402, "args": {"write_json": true, "require_nested_cumulative_type_params": false, "require_unique_project_resource_names": false, "log_format_file": "debug", "static_parser": true, "state_modified_compare_more_unrendered_values": false, "require_ref_searches_node_package_before_root": false, "log_file_max_bytes": 10485760, "project_dir": "/mnt/c/Users/Administrator/Desktop/Everthing Data Projects/Project_2/food_price_etl/dbt_project/kenya_food_analytics", "quiet": false, "defer": false, "log_format": "default", "strict_mode": false, "vars": {}, "version_check": true, "exclude": [], "introspect": true, "populate_cache": true, "which": "run", "indirect_selection": "eager", "require_explicit_package_overrides_for_builtin_materializations": true, "show_all_deprecations": false, "macro_debugging": false, "log_level": "info", "favor_state": false, "requir